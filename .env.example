# Prisma / PostgreSQL
# DATABASE_URL is used by app runtime (can be a pooled connection in production).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zbory_dev?schema=public"
# POSTGRES_URL is used by Prisma Migrate as datasource directUrl (direct/non-pooled in production).
POSTGRES_URL="postgresql://postgres:postgres@localhost:5432/zbory_dev?schema=public"

# NextAuth
NEXTAUTH_SECRET="replace-with-32+chars"
NEXTAUTH_URL="http://localhost:3000"

# Dubidoc
DUBIDOC_API_KEY="replace-with-dubidoc-api-key"
DUBIDOC_ORG_ID="replace-with-dubidoc-org-id"
DUBIDOC_CALLBACK_URL="http://localhost:3000/api/webhooks/dubidoc"
# Optional minimal webhook guard (temporary until signature verification is implemented)
DUBIDOC_WEBHOOK_SECRET=""

# TurboSMS
TURBOSMS_API_KEY="replace-with-turbosms-api-key"
TURBOSMS_SENDER="OSBB"

# OpenAI (Stage 2)
OPENAI_API_KEY="replace-with-openai-api-key"

# Encryption
ENCRYPTION_KEY="replace-with-32+chars"
